```text
# 忽略 Python 缓存
__pycache__/
*.py[cod]

# 忽略虚拟环境
.venv/
__pycache__/

# 忽略巨型地图文件 (极其重要)
*.png
*.jpg
!img/    # 但是保留 img 文件夹里的小图标

# 忽略 IDE 配置文件
.idea/
.vscode/

# 忽略不需要的py文件
draw_markers.py
download_map.py

# 忽略.bat文件
*.bat

# 忽略spec
*.spec

# 忽略不需要的目录
out/
release/
build/
dist/

# 忽略日志
log.txt
crash_log.txt
*.txt